    "title": "C++ reasoning graph (gold, true summary semantics, uncertainty-aware debugging)",
    "source_note": "Designed for C++ reasoning supervision with accepted claims, applications, low-confidence debugging hypotheses, and explicit contradiction structure. Structural hubs are not summary nodes; summary nodes are reserved for later component compression.",
    "relation_convention": {
      "part_of": "child hub or bridge node -> parent hub",
      "example_of": "example or application -> concept or theory",
      "support": "evidence, mechanism, or stronger statement -> claim",
      "contradict": "accepted claim or stronger explanation -> false or weaker claim",
      "refine": "more specific statement -> broader statement",
      "depend": "prerequisite theory -> dependent application or hypothesis",
      "cause": "mechanism or bug source -> downstream effect"
    },
    "notes": [
      "Hub nodes are structural containers only and are not summary nodes.",
      "Summary nodes are reserved for compressed language-level abstractions created after a component becomes mature enough to sparsify.",
      "Hypothesis nodes intentionally keep mid confidence to represent plausible debugging guesses that still need evidence.",
      "Several applications depend on theory nodes so the graph teaches theory-to-code transfer rather than isolated facts.",
      "Some natural edges are intentionally omitted so link_nodes and create_bridge supervision remain meaningful."
    ]
  },
